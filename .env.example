# poller.py reads the environment only (no .env file loading).
# Locally: export these in your shell, or use a tool like direnv.

# ChargePoint (same names as GitHub Actions secrets)
CHARGEPOINT_USER=you@example.com
CHARGEPOINT_PASS=

# Optional: coulomb_sess cookie if SSO / 2FA (see earlier docs)
# CHARGEPOINT_SESSION_TOKEN=

CHARGEPOINT_STATION_IDS=12345678,87654321

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com/

# Local: path to service account JSON. CI: use FIREBASE_KEY secret (full JSON string) instead.
# FIREBASE_CREDENTIALS_PATH=firebase-key.json
